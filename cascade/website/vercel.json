{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/receipts/:path*",
      "has": [{ "type": "host", "value": "testnet\\..*" }],
      "destination": "https://s3.hippius.com/cascade-testnet-manifests/receipts/:path*"
    },
    {
      "source": "/receipts/:path*",
      "destination": "https://s3.hippius.com/cascade-manifests/receipts/:path*"
    }
  ],
  "headers": [
    {
      "source": "/receipts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=15, stale-while-revalidate=30" }
      ]
    },
    {
      "source": "/(index.html)?",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60" }
      ]
    }
  ]
}
